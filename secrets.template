# TER secrets template — env-var names only, never values.
# Copy to ~/.config/ter/secrets.env and fill in. That file is sourced by
# core/01-config.sh if it exists. `ter doctor` warns when one is unset.
#
# Format: one VAR=value per line. Use single quotes around values.
# Comments and blank lines are ignored.

# ── AI / LLM ──
ANTHROPIC_API_KEY=''
OPENROUTER_KEY=''
OPENAI_API_KEY=''

# ── Source control / hosting ──
GH_TOKEN=''            # GitHub personal access token (gh auth login also works)

# ── Cloud ──
GOOGLE_APPLICATION_CREDENTIALS=''   # path to service-account JSON

# ── Misc ──
# Add per-project secrets here. Keep this list minimal — anything sensitive
# should live in ~/.config/ter/secrets.env (gitignored), never in the repo.
